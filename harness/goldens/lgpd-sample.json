  "explanations": {
    "TERM_001": {
      "term_id": "TERM_001",
      "termo_juridico": "dados pessoais",
      "direct_translation": "São suas informações pessoais — tudo que identifica ou pode identificar você",
      "plain_definition": "Qualquer informação que identifique ou possa identificar uma pessoa, como nome, e-mail, CPF, endereço IP ou localização.",
      "practical_example": "Seu nome e e-mail cadastrados num app são dados pessoais. Seu endereço IP, histórico de navegação e localização GPS também — mesmo que você não perceba que os forneceu.",
      "category": "data_collection",
      "icon_id": "user-circle",
      "impact": "high",
      "lgpd_refs": [
        "Art. 5º, I",
        "Art. 18, II"
      ]
    },
    "TERM_006": {
      "term_id": "TERM_006",
      "termo_juridico": "compartilhamento",
      "direct_translation": "É quando a empresa passa seus dados para outras empresas ou pessoas",
      "plain_definition": "Comunicação, transferência ou disponibilização de dados pessoais a terceiros, como parceiros comerciais, anunciantes ou autoridades.",
      "practical_example": "Uma loja online pode compartilhar seu endereço com uma transportadora. Uma rede social pode compartilhar seu perfil comportamental com dezenas de anunciantes.",
      "category": "sharing_third_parties",
      "icon_id": "share-2",
      "impact": "high",
      "lgpd_refs": [
        "Art. 5º, XVI",
        "Art. 18, VII"
      ]
    },
    "TERM_007": {
      "term_id": "TERM_007",
      "termo_juridico": "terceiros",
      "direct_translation": "São outras empresas que recebem acesso aos seus dados, fora da plataforma principal",
      "plain_definition": "Empresas ou entidades externas à plataforma que podem receber ou acessar seus dados, como anunciantes, provedores de analytics ou parceiros de negócios.",
      "practical_example": "'Parceiros e terceiros' em um termo de serviço pode significar dezenas de empresas de analytics, publicidade e tecnologia recebendo suas informações.",
      "category": "sharing_third_parties",
      "icon_id": "users",
      "impact": "high",
      "lgpd_refs": [
        "Art. 18, VII"
      ]
    },
    "TERM_018": {
      "term_id": "TERM_018",
      "termo_juridico": "portabilidade",
      "direct_translation": "É seu direito de pegar seus dados e levar para outra empresa ou plataforma",
      "plain_definition": "Direito do titular de receber seus dados pessoais em formato estruturado e interoperável, podendo transferi-los para outro fornecedor.",
      "practical_example": "Quer mudar de plataforma de fotos Pela portabilidade, você pode pedir que exportem seus álbuns para levar a outro serviço.",
      "category": "user_rights",
      "icon_id": "hard-drive-upload",
      "impact": "medium",
      "lgpd_refs": [
        "Art. 18, V",
        "Art. 9º"
      ]
    },
    "TERM_023c": {
      "term_id": "TERM_023c",
      "termo_juridico": "dados de navegação",
      "direct_translation": "São registros de tudo que você faz online — páginas visitadas, cliques, tempo em cada conteúdo",
      "plain_definition": "Informações geradas automaticamente durante o uso da internet: páginas acessadas, links clicados, tempo de permanência e interações com conteúdo.",
      "practical_example": "Você pesquisa sobre uma doença no Google. Anúncios de planos de saúde aparecem horas depois. Seus dados de navegação foram usados para perfilamento.",
      "category": "data_collection",
      "icon_id": "mouse-pointer-click",
      "impact": "high",
      "lgpd_refs": [
        "Art. 5º, I"
      ]
    },
    "TERM_030": {
      "term_id": "TERM_030",
      "termo_juridico": "eliminação",
      "direct_translation": "É seu direito de pedir para a empresa apagar definitivamente seus dados",
      "plain_definition": "Direito do titular de solicitar a exclusão permanente de dados pessoais tratados com consentimento ou de forma excessiva/desnecessária.",
      "practical_example": "Você fecha sua conta num app de namoro. Os dados de perfil e histórico devem ser eliminados, exceto se houver obrigação legal específica.",
      "category": "user_rights",
      "icon_id": "trash-2",
      "impact": "high",
      "lgpd_refs": [
        "Art. 18, VI",
        "Art. 16"
      ]
    },
    "TERM_032": {
      "term_id": "TERM_032",
      "termo_juridico": "direito de acesso",
      "direct_translation": "É seu direito de pedir para a empresa mostrar tudo que ela sabe sobre você",
      "plain_definition": "Direito do titular de obter confirmação de existência de tratamento e acesso completo aos seus dados pessoais, incluindo categorias, finalidades e destinatários.",
      "practical_example": "Ao solicitar acesso aos dados do Facebook, você recebe centenas de MB incluindo histórico de pesquisas, anúncios clicados e localizações.",
      "category": "user_rights",
      "icon_id": "eye",
      "impact": "medium",
      "lgpd_refs": [
        "Art. 18, I e II",
        "Art. 9º"
      ]
    }
  },
