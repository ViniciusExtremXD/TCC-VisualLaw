{
  "openapi": "3.1.0",
  "info": {
    "title": "Visual Law MVP - API Contract",
    "version": "0.1.0",
    "description": "Contrato tecnico para evolucao futura. O MVP atual e frontend-only e nao possui backend publicado."
  },
  "servers": [
    {
      "url": "https://<usuario>.github.io/<repo>",
      "description": "Hospedagem GitHub Pages (estatico)"
    }
  ],
  "tags": [
    {
      "name": "Status",
      "description": "Endpoints de status e monitoramento planejados."
    },
    {
      "name": "Processing",
      "description": "Endpoints planejados para processamento de texto juridico."
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Healthcheck (planejado)",
        "description": "Endpoint previsto para confirmar disponibilidade do backend quando a API existir.",
        "responses": {
          "200": {
            "description": "Servico saudavel",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "501": {
            "description": "Nao implementado no MVP frontend-only"
          }
        }
      }
    },
    "/v1/process": {
      "post": {
        "tags": [
          "Processing"
        ],
        "summary": "Processar texto legal (planejado)",
        "description": "Contrato previsto para segmentacao, classificacao e destaque de termos. Nao implementado no MVP estatico atual.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProcessRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Processamento concluido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessResponse"
                }
              }
            }
          },
          "501": {
            "description": "Nao implementado no MVP frontend-only"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "version": {
            "type": "string",
            "example": "0.1.0"
          }
        },
        "required": [
          "status",
          "version"
        ]
      },
      "ProcessRequest": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string",
            "example": "X_PRIVACY"
          },
          "text": {
            "type": "string",
            "example": "Ao usar o servico, voce concorda com ..."
          }
        },
        "required": [
          "documentId",
          "text"
        ]
      },
      "ProcessResponse": {
        "type": "object",
        "properties": {
          "clauses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "clause_id": {
                  "type": "string",
                  "example": "C001"
                },
                "text": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                },
                "impact": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                }
              },
              "required": [
                "clause_id",
                "text",
                "category",
                "impact"
              ]
            }
          }
        },
        "required": [
          "clauses"
        ]
      }
    }
  }
}
